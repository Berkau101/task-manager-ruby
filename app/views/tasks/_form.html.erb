<%= form_with model: task do |f| %>
  <%= render "shared/errors", object: task %>

  <div class="field">
    <%= f.label :title, "Başlık" %>
    <%= f.text_field :title %>
  </div>

  <div class="field">
    <%= f.label :description, "Açıklama" %>
    <%= f.text_area :description, rows: 4 %>
  </div>

  <div class="field">
    <%= f.label :status, "Durum" %>
    <%= f.select :status, Task::STATUSES.map { |value, label| [label, value] } %>
  </div>

  <div class="field">
    <%= f.label :due_date, "Son Teslim Tarihi" %>
    <%= f.date_field :due_date %>
  </div>

  <div class="actions">
    <%= f.submit "Kaydet", class: "btn" %>
    <%= link_to "Vazgeç", tasks_path %>
  </div>
<% end %>