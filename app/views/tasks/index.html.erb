<h1>Görevler</h1>

<%= link_to "+ Yeni Görev", new_task_path, class: "btn" %>

<div class="filters">
  <%= link_to "Tümü",              tasks_path,                      class: ("active" if @filter.blank?) %>
  <%= link_to "Bekleyen",          tasks_path(filter: "pending"),   class: ("active" if @filter == "pending") %>
  <%= link_to "Tamamlanan",        tasks_path(filter: "completed"), class: ("active" if @filter == "completed") %>
  <%= link_to "Yaklaşan (7 gün)",  tasks_path(filter: "due_soon"),  class: ("active" if @filter == "due_soon") %>
</div>

<% if @tasks.any? %>
  <table>
    <thead>
      <tr>
        <th>Başlık</th>
        <th>Durum</th>
        <th>Son Teslim</th>
        <th>Kullanıcı</th>
        <th>İşlemler</th>
      </tr>
    </thead>
    <tbody>
      <% @tasks.each do |task| %>
        <tr>
          <td><%= link_to task.title, task %></td>
          <td><%= task.status_label %></td>
          <td><%= task.due_date %></td>
          <td><%= task.user.name %></td>
          <td>
            <%= link_to "Detay", task %>
            <%= link_to "Düzenle", edit_task_path(task) %>
            <%= button_to "Sil", task, method: :delete,
                          form: { data: { turbo_confirm: "Bu görevi silmek istediğine emin misin?" } },
                          class: "link-danger" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>Bu filtreye uygun görev bulunmuyor.</p>
<% end %>