<h1>Kullanıcılar</h1>

<%= link_to "+ Yeni Kullanıcı", new_user_path, class: "btn" %>

<% if @users.any? %>
  <table>
    <thead>
      <tr>
        <th>Ad</th>
        <th>E-posta</th>
        <th>Görev Sayısı</th>
        <th>İşlemler</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td><%= user.name %></td>
          <td><%= user.email %></td>
          <td><%= user.tasks.size %></td>
          <td>
            <%= button_to "Sil", user, method: :delete,
                          form: { data: { turbo_confirm: "Bu kullanıcıyı silmek istediğine emin misin?" } },
                          class: "link-danger" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>Henüz kullanıcı yok.</p>
<% end %>